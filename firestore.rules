rules_version = '2';

// AcadFlow Firestore Security Rules — role-based
// ----------------------------------------------
// Auth model: the teacher signs in with a real admin email; students sign in
// with a synthetic email <studentNumber>@acadflow.app. Every request is
// authenticated (request.auth != null) once signed in.
//
// Goals of these rules:
//   • Everyone signed in can READ the collections the app listens to (the app
//     subscribes to whole collections, so reads stay broad but require login).
//   • Only the TEACHER can write class config, grade weights, app config and
//     online meetings, and only the teacher can create/delete student records.
//   • Students may update their own-facing data (profile, attendance check-in,
//     messages, submissions, quiz results, etc.) but CANNOT change grade fields.
//     Grades and grade components on a student record can only be written by the
//     teacher.
//
// COLLECTIONS COVERED (every collection the client reads/writes is matched below;
// an unmatched collection is denied by default, so ADD a match here whenever a new
// feature introduces a new top-level collection — otherwise it will silently fail):
//   students · portal/* (classes, config, settings, admin, rubricLibrary) ·
//   onlineMeetings · rtcRooms/* (in-app class WebRTC signaling) · auditLog ·
//   messages · typing · activities · notifications · quizzes · announcements ·
//   attendanceSessions · excuseRequests · studentFeedback · pushTokens ·
//   studentSecrets.  resetSessions/* is intentionally server-only (see bottom).
//
// HOW TO APPLY (these rules only take effect once PUBLISHED):
//   Firebase Console → project (collegeportal-d2b98) → Build → Firestore
//   Database → Rules tab → replace everything with this file → Publish.
//   If a write that should work is denied, it usually means the deployed rules
//   are older than this file — re-publish.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // The teacher account. Resilient on purpose so the teacher is never locked
    // out of every admin write by a single hardcoded value:
    //   • the primary admin email, OR
    //   • any account carrying a custom auth claim `admin: true` (set via the
    //     Admin SDK if the email ever changes or a second staff account is added).
    // Add more emails to the list if more staff need teacher rights.
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.get('admin', false) == true
          || request.auth.token.email in [
               'markgalvez@ucc-caloocan.edu.ph'
             ]
        );
    }

    // True when a write does NOT touch grade-bearing fields on a student doc.
    // Defensive: on an update `resource` always exists, but guard for null so a
    // misfire evaluates to a clean allow/deny instead of erroring out.
    function gradeFieldsUntouched() {
      return resource == null
        || !request.resource.data.diff(resource.data)
             .affectedKeys().hasAny(['grades', 'gradeComponents']);
    }

    // True when an UPDATE changes ONLY the given top-level keys (a subset of
    // `keys`). Used to let students touch the collaborative fields of a
    // teacher-owned doc (e.g. add a comment / like) WITHOUT being able to edit
    // its content (the announcement body, the quiz answer key, etc.). On create
    // `resource` is null, so this returns false there - creates are gated
    // separately to teacher-only.
    function onlyAffects(keys) {
      return resource != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Identity verification is server/teacher authority only — a student's own
    // device must never be able to FORGE itself to "verified" (that gate guards
    // portal access). We block only the upgrade to verified=true when it wasn't
    // already true; leaving it false/absent or keeping an existing true is fine.
    // (Allowing harmless "downgrades" avoids denying ordinary student writes that
    // carry a slightly stale local copy of the account.)
    function accountVerifyNotForged() {
      return !('account' in request.resource.data)
        || request.resource.data.account.get('verified', false) != true
        || (resource != null && 'account' in resource.data
            && resource.data.account.get('verified', false) == true);
    }

    // The face SIGNATURE (128-number descriptor) lives in the server-only
    // faceSignatures/* collection (unmatched below → denied to all clients), so
    // it can never be read/replayed or forged from a device. The student doc
    // keeps only a cheap UI flag, account.faceResetEnabled, set by the server on
    // enrollment. A student must not be able to flip it on themselves — mirror
    // accountVerifyNotForged: block only the upgrade to true; keeping or clearing
    // it is harmless (the real gate is the server-side signature), so ordinary
    // student writes carrying a stale account copy still pass.
    function faceResetFlagNotForged() {
      return !('account' in request.resource.data)
        || request.resource.data.account.get('faceResetEnabled', false) != true
        || (resource != null && 'account' in resource.data
            && resource.data.account.get('faceResetEnabled', false) == true);
    }

    // ── Student records ───────────────────────────────────────────────────
    // Read: any signed-in user (the app listens to the whole collection).
    // Create/Delete: teacher only (prevents forging or wiping records).
    // Update: teacher freely; students may update their own-facing fields
    //         (profile, attendance check-in, quizResults cache, …) but never
    //         grades / gradeComponents.
    //
    // ⚠ KNOWN GAP (C1, cannot be fixed by rules alone): Firestore rules are
    // document-level, not field-level, for READS. Because every signed-in user
    // can read this whole collection, any student can read EVERY student record,
    // including the password hash (account.pass) and security-answer hashes. The
    // real fix is to MOVE those secret fields OUT of the student doc into a
    // server-only collection (like faceSignatures/* already is) so the client
    // never sees them - then this broad read is harmless (only non-secret roster
    // data is exposed). Until then, treat account.pass as readable by all users.
    match /students/{sid} {
      allow read:   if signedIn();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (signedIn() && gradeFieldsUntouched() && accountVerifyNotForged() && faceResetFlagNotForged());
    }

    // ── Teacher-only configuration ────────────────────────────────────────
    // Class list, grade weights / equivalence scale (settings), the app/EJS
    // config, and the saved rubric library all live under portal/*. Read by
    // everyone signed in; written only by the teacher.
    match /portal/{docId}             { allow read: if signedIn(); allow write: if isAdmin(); }

    // Online meetings are scheduled and controlled by the teacher.
    match /onlineMeetings/{docId}     { allow read: if signedIn(); allow write: if isAdmin(); }

    // In-app class rooms: EPHEMERAL WebRTC signaling for the built-in video
    // classroom (participants + offer/answer/ICE messages under
    // rtcRooms/{meetingId}/...). Students must be able to write their own
    // participant + signal docs here, so this stays login-gated like typing/*.
    // Docs are transient: peers delete their own on leave and the professor's
    // End-class purges stragglers. No grades or content ever live here.
    match /rtcRooms/{document=**}     { allow read, write: if signedIn(); }

    // Audit log: append-only history of admin actions (grade edits, deletions).
    // Teacher-only — written by the admin client and read only in the Audit Log
    // tab. The cron uses the service account, which bypasses these rules.
    match /auditLog/{docId}           { allow read, write: if isAdmin(); }

    // ── Teacher-owned content with student collaboration ─────────────────
    // PRINCIPLE: the teacher OWNS the content (creates/deletes it and edits its
    // body); students may only touch the collaborative side-fields. Previously
    // every one of these was `read, write: if signedIn()`, which let ANY student
    // forge or delete announcements/quizzes/activities and (for announcements)
    // inject HTML into the `message` field that renders in the teacher's admin
    // view. The `onlyAffects(...)` allow-lists below are derived from the actual
    // client write helpers; VERIFY them in the Rules Playground / emulator before
    // publishing, and extend a list if a feature writes a new collaborative field.

    // Announcements: teacher posts; students may only add comments / likes / follows.
    // Student writers (persistence.js): fbAddAnnouncementComment -> {comments},
    // toggle like -> {likes}, toggle follow -> {followers}.
    match /announcements/{docId} {
      allow read:           if signedIn();
      allow create, delete: if isAdmin();
      allow update:         if isAdmin() || (signedIn() && onlyAffects(['comments', 'likes', 'followers']));
    }

    // Quizzes: teacher authors the quiz (questions + answer keys); a student may
    // only write their own attempt under the `submissions` map (QuizTab writes
    // `submissions.<studentId>`), never `questions`/`answer`. NOTE residual: the
    // map-level rule can't pin the sub-key to the caller, so a student could in
    // theory overwrite another student's submission - acceptable vs. the prior
    // "edit the answer key" exposure; tighten server-side later if needed.
    match /quizzes/{docId} {
      allow read:           if signedIn();
      allow create, delete: if isAdmin();
      allow update:         if isAdmin() || (signedIn() && onlyAffects(['submissions', 'progress']));
    }

    // Activities + attendance sessions: only the teacher creates or deletes them;
    // students update them in place (activity submissions, attendance check-in).
    // Leaving student UPDATE broad keeps every submission/check-in flow working;
    // create/delete is now teacher-only so students can't forge or wipe them.
    match /activities/{docId} {
      allow read:           if signedIn();
      allow create, delete: if isAdmin();
      allow update:         if signedIn();
    }
    match /attendanceSessions/{docId} {
      allow read:           if signedIn();
      allow create, delete: if isAdmin();
      allow update:         if signedIn();
    }

    // ── Shared collections students legitimately write to ────────────────
    // These are genuinely collaborative (DMs/groups, cross-user notifications,
    // excuse requests, feedback, device tokens). They stay login-only because a
    // correct ownership gate needs per-document author checks; the proper fix is
    // to route these writes through the server (service account) so the client
    // never writes another user's doc. Tracked as follow-up, not a quick win.
    match /messages/{docId}           { allow read, write: if signedIn(); }
    // Ephemeral "X is typing" presence per chat (direct_/group_ keys).
    match /typing/{docId}             { allow read, write: if signedIn(); }
    match /notifications/{docId}      { allow read, write: if signedIn(); }
    match /excuseRequests/{docId}     { allow read, write: if signedIn(); }
    // Student feedback (enhancements / bug reports / requests): students create &
    // read; the teacher updates the status from the Feedback Hub.
    match /studentFeedback/{docId}    { allow read, write: if signedIn(); }
    match /pushTokens/{docId}         { allow read, write: if signedIn(); }

    // Server-only student secrets, extracted from the student doc: the temp
    // password hash (account.pass) and the security-question answer hash. NEVER
    // client-readable - this is what closes the C1 gap where the broad `students`
    // read exposed every student's password hash. The professor (admin) writes the
    // temp-password hash at provisioning; the server (service account, which
    // bypasses these rules) writes the security answer and reads both for the
    // verify-claim / verify-security-answer endpoints. Students never touch it.
    match /studentSecrets/{sid} {
      allow read:  if false;
      allow write: if isAdmin();
    }

    // resetSessions/* and faceSignatures/* are intentionally NOT matched here —
    // they are written and read only by the server (service account), which
    // bypasses these rules. Leaving them unmatched denies all direct client
    // access, which is exactly what we want (the face descriptor must never be
    // client-readable or client-writable).
  }
}
