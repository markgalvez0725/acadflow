# ── SECURITY: All environment secrets must be set in .env.local (never commit to git) ──

# ── Password hashing salt (minimum 16 characters, must be unique per deployment) ──
VITE_PASS_SALT=your_unique_password_salt_here_min_16_chars

# ── EmailJS encryption secrets (for encrypting/decrypting EmailJS config in storage) ──
VITE_EJS_SECRET=your_unique_ejs_encryption_key_here_min_16_chars
VITE_EJS_SALT=your_unique_ejs_salt_here_min_16_chars

# ── Firebase config encryption secrets (for encrypting/decrypting Firebase credentials) ──
VITE_FB_SECRET=your_unique_firebase_encryption_key_here_min_16_chars
VITE_FB_SALT=your_unique_firebase_salt_here_min_16_chars

# ── Admin credentials encryption key (minimum 16 characters) ──
VITE_ADMIN_CRYPTO_KEY=your_unique_admin_crypto_key_here_min_16_chars

# ── Third-party API keys ──
VITE_GROQ_API_KEY=your_groq_api_key_here

# IMPORTANT SECURITY NOTES:
# 1. Generate unique values for each deployment (never reuse across environments)
# 2. Use strong random strings (minimum 16 characters recommended)
# 3. Store this file in .env.local, which is NOT committed to git
# 4. Example: Generate with: head -c 32 /dev/urandom | base64
# 5. Keep backups of these values — changing them will break decryption of stored data
