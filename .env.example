# ── SECURITY: All environment secrets must be set in .env.local (never commit to git) ──

# ── Password hashing salt (minimum 16 characters, must be unique per deployment) ──
VITE_PASS_SALT=your_unique_password_salt_here_min_16_chars

# ── EmailJS encryption secrets (for encrypting/decrypting EmailJS config in storage) ──
VITE_EJS_SECRET=your_unique_ejs_encryption_key_here_min_16_chars
VITE_EJS_SALT=your_unique_ejs_salt_here_min_16_chars

# ── Firebase config encryption secrets (for encrypting/decrypting Firebase credentials) ──
VITE_FB_SECRET=your_unique_firebase_encryption_key_here_min_16_chars
VITE_FB_SALT=your_unique_firebase_salt_here_min_16_chars

# ── Admin credentials encryption key (minimum 16 characters) ──
VITE_ADMIN_CRYPTO_KEY=your_unique_admin_crypto_key_here_min_16_chars

# ── Web Push (Firebase Cloud Messaging) — optional ──
# Web Push certificate "key pair" from Firebase Console →
# Project settings → Cloud Messaging → Web Push certificates.
# When empty, push is silently disabled (in-app notifications still work).
VITE_FB_VAPID_KEY=

# ── Server-side API keys (Vercel env vars — NOT VITE_ vars, never bundled) ──
# These are read by the /api/* serverless functions via process.env. Do NOT
# prefix them with VITE_ (that prefix is reserved for client-bundled values).
#
# GROQ_API_KEY      — Groq (Llama) quiz generation. Legacy name VITE_GROQ_API_KEY
#                     still works as a fallback, but rename it to GROQ_API_KEY.
# GEMINI_API_KEY    — Google Gemini (free) for quiz/activity AI + photo check.
#                     Create at https://aistudio.google.com/app/apikey
# GEMINI_MODEL      — optional override, defaults to gemini-2.5-flash.
# FCM_SERVICE_ACCOUNT      — full service-account JSON string; required to send
#                     pushes from /api/send-push. Firebase Console → Project
#                     settings → Service accounts → Generate new private key.
# FB_ADMIN_SERVICE_ACCOUNT — service-account JSON for the password-reset
#                     endpoints (falls back to FCM_SERVICE_ACCOUNT — same project).
# FB_PROJECT_ID     — optional. Firebase project id used to verify the caller's
#                     ID token on the protected /api endpoints. Falls back to the
#                     service account's project_id, then a built-in default.

# IMPORTANT SECURITY NOTES:
# 1. Generate unique values for each deployment (never reuse across environments)
# 2. Use strong random strings (minimum 16 characters recommended)
# 3. Store this file in .env.local, which is NOT committed to git
# 4. Example: Generate with: head -c 32 /dev/urandom | base64
# 5. Keep backups of these values — changing them will break decryption of stored data
